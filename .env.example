SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated list of Google accounts allowed to sign in.
ADMIN_EMAIL=you@gmail.com,teammate@gmail.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Supabase — see README "Supabase setup" for exact dashboard clicks.
# 1) DATABASE_URL  = Connect → ORM / direct Postgres URI (replace [YOUR-PASSWORD])
DATABASE_URL=
# 2) SUPABASE_URL  = Project Settings → API → Project URL
# 3) SUPABASE_SERVICE_KEY = Project Settings → API → service_role secret (sb_secret_... or eyJ...)
#    Publishable/anon keys cannot upload files. Optional alias: SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Legacy name — only used when it is a service_role secret, not a publishable key.
SUPABASE_KEY=

# Gemini — embeddings and chat (optional: GEMINI_MODEL=gemini-2.0-flash-lite)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite

ENVIRONMENT=development

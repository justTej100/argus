# ─────────────────────────────────────────────────────────────────
# Argus — single root .env
# Copy this file to .env and fill in what you need.
# The backend and frontend both read from this file automatically.
# ─────────────────────────────────────────────────────────────────

# ── AI (at least one required for full responses) ─────────────────
# DeepSeek — ~$0.001 per chat message. Get a key at platform.deepseek.com
DEEPSEEK_API_KEY=

# Gemini — free tier (1M tokens/day). Get a key at aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Optional: higher GitHub API rate limits ───────────────────────
# Without this you get 60 req/hour. With it: 5000 req/hour.
GITHUB_TOKEN=

# ── Optional: extra data sources ─────────────────────────────────
# Exa semantic web search (1000 free searches/month) — exa.ai
EXA_API_KEY=

# ScrapeCreators — TikTok, Instagram, X (100 free credits) — scrapecreators.com
SCRAPECREATORS_API_KEY=

# ── Optional: Postgres + pgvector (for persisted embeddings) ──────
# If not set, embeddings are computed in-memory per request.
# Use Supabase (free tier) — supabase.com → Settings → Database → URI
DATABASE_URL=

# ── Frontend ──────────────────────────────────────────────────────
# Override these if your backend runs somewhere other than localhost.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_KEY=demo-key-argus

SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated list of Google accounts allowed to sign in.
ADMIN_EMAIL=you@gmail.com,teammate@gmail.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Supabase — see README "Supabase setup" for exact dashboard clicks.
# 1) DATABASE_URL  = Connect → ORM / direct Postgres URI (replace [YOUR-PASSWORD])
# 2) SUPABASE_URL  = Project Settings → API → Project URL
# 3) SUPABASE_KEY  = Project Settings → API → service_role (secret, NOT anon)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=

# AI providers
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

ENVIRONMENT=development

# =============================================================================
# Argus Study Buddy — copy to .env and fill in values
# Full setup guide: README.md "How to get each key"
# =============================================================================

# --- Auth (required) ---
# Random secret for signing session cookies:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# Google account(s) with full admin access (upload/delete/admin UI). Anyone can sign in with Google as a guest.
ADMIN_EMAIL=you@gmail.com

# Guest chat limits (admins unlimited)
# GUEST_CHAT_COOLDOWN_SECONDS=300
# GUEST_CHAT_DAILY_LIMIT=10

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly (local example below)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Supabase Postgres (recommended) ---
# Dashboard → Connect → URI (replace [YOUR-PASSWORD], URL-encode special chars)
DATABASE_URL=

# --- Supabase Storage (recommended for production) ---
# Project Settings → API → Project URL
SUPABASE_URL=
# Project Settings → API → service_role SECRET (not anon/publishable)
SUPABASE_SERVICE_KEY=
# Optional alias: SUPABASE_SERVICE_ROLE_KEY=
# Legacy: SUPABASE_KEY= only if it is the service_role secret
SUPABASE_BUCKET=argus-pdfs

# local = PDFs in uploaded_pdfs/  |  supabase = cloud bucket (default when ENVIRONMENT=production)
STORAGE_BACKEND=local

# --- Gemini (required) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Gmail flashcards (optional) ---
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
# APP_BASE_URL=https://your-app.onrender.com

# development | production (production → secure cookies + supabase storage default)
ENVIRONMENT=development

# Re-upload textbooks after schema changes so vectors land in argus_vectors.
